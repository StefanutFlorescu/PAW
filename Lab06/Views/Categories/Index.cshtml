@model List<Lab06.Models.Category>

<h1>Categorii</h1>

<ul class="list-group">
    @foreach (var c in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @c.Name
            <span class="badge bg-secondary rounded-pill">@c.Id</span>
        </li>
    }
</ul>
