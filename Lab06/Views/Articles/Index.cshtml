<nav class="mt-4 d-flex justify-content-center">
    @{ 
        var current = (int)ViewBag.CurrentPage;
        var pageSize = (int)ViewBag.PageSize;
        var total = (int)ViewBag.TotalCount;
        var totalPages = (int)Math.Ceiling(total / (double)pageSize);
    }
    <div>
        @if (current > 1)
        {
            <a asp-action="Index" asp-route-page="@(current - 1)" asp-route-categoryId="@ViewBag.SelectedCategoryId" class="btn btn-outline-primary me-2">← Previous</a>
        }
        else
        {
            <button class="btn btn-outline-secondary me-2" disabled>← Previous</button>
        }

        <span class="mx-2">Pagina @current din @totalPages</span>

        @if (current < totalPages)
        {
            <a asp-action="Index" asp-route-page="@(current + 1)" asp-route-categoryId="@ViewBag.SelectedCategoryId" class="btn btn-outline-primary ms-2">Next →</a>
        }
        else
        {
            <button class="btn btn-outline-secondary ms-2" disabled>Next →</button>
        }
    </div>
</nav>
