@model ArticleViewModel

<h1>@Model.Title</h1>
@if (Model.ImagePath != null)
{
    <img src="@Model.ImagePath"
         alt="@Model.Title"
         class="img-fluid rounded mb-3"
         style="max-height: 400px; object-fit: cover; width: 100%;" />
}

<p><strong>Category:</strong> @Model.CategoryName</p>
<p><strong>Data publicării:</strong> @Model.PublishedAt.ToShortDateString()</p>
<p>@Model.Content</p>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="mb-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editare</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Ștergere</a>
    </div>
}

<a asp-action="Index">← Înapoi la listă</a>